{
  "name": "origo-trade",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": "20.x || 24.x"
  },
  "scripts": {
    "node:version": "node -v",
    "install:all": "npm --prefix frontend install && npm --prefix backend install",
    "dev": "npm --prefix frontend run dev",
    "api:dev": "npm --prefix backend run dev",
    "dev:full": "npm --prefix frontend run dev:full",
    "build": "npm --prefix frontend run build",
    "lint": "npm --prefix frontend run lint",
    "test": "npm --prefix frontend run test",
    "backend:check": "npm --prefix backend run check",
    "stock:check": "npm --prefix backend run stock:check"
  }
}
